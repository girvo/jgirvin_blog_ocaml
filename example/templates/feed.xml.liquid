<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site_title }}</title>
    <link>https://jgirvin.com</link>
    <description>{{ site_title }}</description>
    <atom:link href="https://jgirvin.com/feed.xml" rel="self" type="application/rss+xml"/>
    {% for post in recent_posts %}
    <item>
      <title><![CDATA[{{ post.title }}]]></title>
      <link>https://jgirvin.com{{ post.link }}</link>
      <guid>https://jgirvin.com{{ post.link }}</guid>
      <pubDate>{{ post.date }}</pubDate>
      <description><![CDATA[{{ post.description }}]]></description>
    </item>
    {% endfor %}
  </channel>
</rss>